# ─── MYCELIUM ENVIRONMENT CONFIGURATION ───────────────────────────────────────
# Copy to .env and configure for your environment

# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ─── DATABASE ─────────────────────────────────────────────────────────────────
POSTGRES_DB=mycelium
POSTGRES_USER=mycelium
POSTGRES_PASSWORD=mycelium_secret
DATABASE_URL=postgresql+asyncpg://mycelium:mycelium_secret@localhost:5432/mycelium
DATABASE_SYNC_URL=postgresql://mycelium:mycelium_secret@localhost:5432/mycelium

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6379/1
REDIS_PUBSUB_URL=redis://localhost:6379/2

# ─── SECURITY ─────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── EVOLUTION ENGINE ─────────────────────────────────────────────────────────
MUTATION_RATE=0.15
CROSSOVER_RATE=0.05
EXTINCTION_THRESHOLD=0.20
ELITE_SURVIVAL_RATIO=0.10
MAX_POPULATION_SIZE=50
EVOLUTION_CYCLE_INTERVAL_SEC=30
MIN_BENCHMARK_SAMPLES=3
FITNESS_WINDOW_SIZE=10

# ─── SANDBOX EXECUTION ────────────────────────────────────────────────────────
SANDBOX_CPU_QUOTA=50000
SANDBOX_CPU_PERIOD=100000
SANDBOX_MEM_LIMIT=256m
SANDBOX_TIMEOUT_SEC=30
SANDBOX_NETWORK=mycelium-sandbox-net
SANDBOX_BASE_IMAGE=python:3.12-slim
MAX_GENOME_SIZE_KB=512

# ─── WORKER ───────────────────────────────────────────────────────────────────
WORKER_ID=worker-01
WORKER_CONCURRENCY=4
WORKER_QUEUE_POLL_INTERVAL=0.5

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=development

# ─── MONITORING ───────────────────────────────────────────────────────────────
METRICS_ENABLED=true
TELEMETRY_FLUSH_INTERVAL=5
